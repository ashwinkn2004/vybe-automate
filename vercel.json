{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/callback",
      "dest": "/api/callback.js"
    },
    {
      "src": "/api/tracks",
      "dest": "/api/tracks.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
